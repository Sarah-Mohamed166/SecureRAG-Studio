# AI provider
GEMINI_API_KEY=replace_with_your_api_key
GEMINI_MODEL=gemini-2.5-flash

# Provider settings
PROVIDER_TIMEOUT_MS=15000

# Retrieval trust threshold (0-1). Evidence scoring below this is not sent
# to the model. Owned by platform config; tunable by the evaluation team
# without touching answer-service.ts.
RETRIEVAL_SCORE_THRESHOLD=0.35
